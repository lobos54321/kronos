# ============================================================
# 数据获取模式
# ============================================================
# api = 通过 HTTP API 从现有系统获取 (Zeabur 部署)
# local = 直接读取本地 SQLite 文件 (本地调试)
DATA_MODE=api

# ============================================================
# 现有系统 API 连接 (DATA_MODE=api 时使用)
# ============================================================
SENTINEL_API_URL=https://sentiment-arbitrage.zeabur.app
SENTINEL_TOKEN=mytoken54321

# ============================================================
# 本地文件路径 (DATA_MODE=local 时使用)
# ============================================================
# SENTIMENT_DB_PATH=/path/to/sentiment-arbitrage-system/server_sentiment_arb.db
# PAPER_DB_PATH=/path/to/sentiment-arbitrage-system/server_paper.db
# KLINE_DB_PATH=/path/to/sentiment-arbitrage-system/data/kline_cache.db

# ============================================================
# 影子系统数据库
# ============================================================
SHADOW_DB_PATH=/app/data/shadow_trades.db

# ============================================================
# Kronos 模型
# ============================================================
KRONOS_DEVICE=cpu
# KRONOS_TOKENIZER=NeoQuasar/Kronos-Tokenizer-base
# KRONOS_MODEL=NeoQuasar/Kronos-small

# ============================================================
# GBDT 模型
# ============================================================
GBDT_MODEL_PATH=/app/models/gbdt_model.pkl

# ============================================================
# 运行参数
# ============================================================
POLL_INTERVAL=30
